# XMem Go runs separately from the production Python service.
API_HOST=0.0.0.0
API_PORT=8081
API_KEYS='["dev-xmem-go-key"]'
CORS_ORIGINS='["http://localhost:3000","http://localhost:5173"]'
RATE_LIMIT=60
MAX_REQUEST_BODY_BYTES=10485760

# Local/dev defaults avoid production memory data.
VECTOR_STORE_PROVIDER=memory
PINECONE_NAMESPACE=xmem-go-dev
PINECONE_INDEX_NAME=xmem-index
# Optional. If empty, xmem-go asks Pinecone control plane for the index host.
PINECONE_HOST=
PINECONE_DIMENSION=768
PINECONE_METRIC=cosine
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# LLM/model settings. The initial Go server has a local deterministic fallback.
FALLBACK_ORDER='["ollama","gemini","claude","openai","openrouter","bedrock"]'
TEMPERATURE=0.4
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=local-hash
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_MODEL=claude-3-5-sonnet
OPENAI_MODEL=gpt-4.1-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Optional provider keys.
GEMINI_API_KEY=
CLAUDE_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_REGION=us-east-1

# App/auth stores.
APP_STORE_PROVIDER=memory
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=xmem_go
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

# Temporal graph settings reserved for the real Neo4j adapter.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
